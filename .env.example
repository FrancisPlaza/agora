# Supabase — local dev (from `supabase status` after `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# Public site URL — used for the magic-link callback redirect
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email — approval notification)
# Server-only. Both vars are read by lib/email/send.ts.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Agora <agora@e.plaza.ph>"

# Beadle contacts shown on the rejected screen.
# Newline-separated; each line is a label (any format) shown verbatim.
# Leave empty to show a generic "contact your beadle" line.
NEXT_PUBLIC_BEADLE_CONTACT="Beadle Lim · jlim@sanbeda.edu.ph
Beadle Cruz · mcruz@sanbeda.edu.ph"

# Source repo link shown in the landing footer. Leave empty to render
# the commit SHA without an outbound link (local dev default).
NEXT_PUBLIC_REPO_URL=https://github.com/FrancisPlaza/agora
